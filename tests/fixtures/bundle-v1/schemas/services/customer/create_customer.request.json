{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["email", "name"],
  "properties": {
    "email": {"type": "string", "format": "email"},
    "name":  {"type": "string", "minLength": 1, "maxLength": 200},
    "phone": {"type": "string", "pattern": "^\\+?[0-9 ()-]{7,30}$"}
  },
  "additionalProperties": false
}
