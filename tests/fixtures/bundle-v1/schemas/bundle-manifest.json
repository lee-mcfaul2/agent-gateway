{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-security.io/schemas/bundle-manifest.json",
  "title": "Bundle manifest",
  "description": "Top-level manifest inside every bundle. Pins bundle version, schema-library version, and the per-MCP tool catalog with per-side digests.",
  "type": "object",
  "required": ["bundle_version", "schema_library_version", "build", "envelope_cost_caps", "services"],
  "properties": {
    "bundle_version":         { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-[0-9A-Za-z.-]+)?$" },
    "schema_library_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-[0-9A-Za-z.-]+)?$" },
    "build": {
      "type": "object",
      "required": ["timestamp", "source_commit", "builder_id"],
      "properties": {
        "timestamp":     { "type": "string", "format": "date-time" },
        "source_commit": { "type": "string", "pattern": "^[0-9a-f]{7,40}$" },
        "builder_id":    { "type": "string" }
      }
    },
    "envelope_cost_caps": {
      "type": "object",
      "required": ["max_iterations", "max_wallclock_ms", "max_cost_usd"],
      "properties": {
        "max_iterations":   { "type": "integer", "minimum": 1 },
        "max_wallclock_ms": { "type": "integer", "minimum": 1 },
        "max_cost_usd":     { "type": "number",  "minimum": 0 }
      }
    },
    "services": {
      "type": "array",
      "description": "One entry per MCP. Each lists the tools that MCP exposes; per-tool schemas live at services/<mcp>/<tool>.{request,response}.json.",
      "items": {
        "type": "object",
        "required": ["mcp", "tools"],
        "properties": {
          "mcp":  { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
          "tools": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["name", "request_digest", "response_digest"],
              "properties": {
                "name":            { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
                "request_digest":  { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
                "response_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
                "write":           { "type": "boolean", "default": false },
                "requires_permissions": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            }
          }
        }
      }
    }
  },
  "additionalProperties": false
}
